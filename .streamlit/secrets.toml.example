# Copy this file to .streamlit/secrets.toml and fill in your values.
# .streamlit/secrets.toml is gitignored — never commit real credentials.
#
# On Streamlit Community Cloud: paste these key/values into
# App Settings > Secrets (no file needed).

[snowflake]
account   = "your_org-your_account"   # e.g. "spoton-prod"
user      = "your_email@spoton.com"
token     = "your_pat_here"
role      = "REPORTER"
warehouse = "REPORTING_WH"
database  = "ANALYTICS"
schema    = "DBT_PROD"

[auth]
redirect_uri       = "http://localhost:8501/oauth2callback"  # use your Streamlit Cloud URL for prod
cookie_secret      = "replace-with-a-long-random-string"

[auth.google]
client_id            = "your-client-id.apps.googleusercontent.com"
client_secret        = "your-client-secret"
server_metadata_url  = "https://accounts.google.com/.well-known/openid-configuration"
