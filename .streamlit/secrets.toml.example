# Copy this file to .streamlit/secrets.toml and fill in your values.
# .streamlit/secrets.toml is gitignored — never commit real credentials.
#
# On Streamlit Community Cloud: paste these key/values into
# App Settings > Secrets (no file needed).

[snowflake]
account   = "your_org-your_account"   # e.g. "spoton-prod"
user      = "your_email@spoton.com"
token     = "your_pat_here"
role      = "REPORTER"
warehouse = "REPORTING_WH"
database  = "ANALYTICS"
schema    = "DBT_PROD"
